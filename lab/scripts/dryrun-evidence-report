#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
cd "$ROOT"

URL="${1:-http://127.0.0.1:3000}"
TS="$(date -u +%Y%m%dT%H%M%SZ)"
OUT="lab/evidence/$TS-dryrun-report"

mkdir -p "$OUT"

echo "[+] OpenMythos dry-run evidence report"
echo "[+] URL: $URL"
echo "[+] Output: $OUT"

echo "[+] Preflight: checking local lab target"
if ! curl -fsS -I --max-time 10 "$URL" >/dev/null; then
  echo "[!] Local lab target is not reachable: $URL"
  echo "    Start it with: sudo ./lab/scripts/labctl up"
  exit 2
fi

echo "[+] Running passive audit"
./lab/scripts/passive-audit | tee "$OUT/passive-audit.console.txt"

cp lab/reports/latest_lab_report.md "$OUT/latest_lab_report.md" 2>/dev/null || true
cp lab/reports/latest_lab_report.json "$OUT/latest_lab_report.json" 2>/dev/null || true

echo "[+] Running active dry-run planner"
./lab/scripts/active-dry-run "$URL" "I_APPROVE_ACTIVE_LOCAL_ONLY_TEST" \
  | tee "$OUT/active-dry-run.json"

echo "[+] Running bounded fuzzing dry-run planner"
./lab/scripts/fuzz-dry-run "$URL" "I_APPROVE_BOUNDED_LOCAL_ONLY_FUZZING" \
  | tee "$OUT/fuzz-dry-run.json"

echo "[+] Capturing audit log tail"
tail -n 300 lab_audit/logs/mcp_audit.jsonl > "$OUT/mcp_audit_tail.jsonl" 2>/dev/null || true

{
  echo "# Git State"
  git log --oneline --decorate -20
  echo
  git status --short
  echo
  echo "# Tags at HEAD"
  git tag --points-at HEAD
} > "$OUT/git_state.txt"

{
  echo "# Docker State"
  docker ps 2>/dev/null || sudo docker ps
  echo
  ss -ltnp | grep 3000 || true
} > "$OUT/docker_state.txt"

python - "$OUT" "$URL" <<'PY'
import json
import sys
from pathlib import Path

out = Path(sys.argv[1])
url = sys.argv[2]

def load_json(name):
    path = out / name
    if not path.exists():
        return {}
    return json.loads(path.read_text())

active = load_json("active-dry-run.json")
fuzz = load_json("fuzz-dry-run.json")
lab_report = load_json("latest_lab_report.json")

summary = {
    "ok": True,
    "mode": "active_lab_dryrun_evidence_report",
    "url": url,
    "passive_report_present": bool(lab_report),
    "active_dry_run": {
        "ok": active.get("ok"),
        "blocked": active.get("blocked"),
        "executes_requests": active.get("executes_requests"),
        "execution_blocked": active.get("execution_blocked"),
        "planned_request_count": active.get("planned_request_count"),
        "reason": active.get("reason"),
    },
    "fuzz_dry_run": {
        "ok": fuzz.get("ok"),
        "blocked": fuzz.get("blocked"),
        "executes_requests": fuzz.get("executes_requests"),
        "execution_blocked": fuzz.get("execution_blocked"),
        "planned_case_count": fuzz.get("planned_case_count"),
        "reason": fuzz.get("reason"),
    },
    "safety_assertions": [
        "active dry-run executed zero HTTP requests",
        "bounded fuzz dry-run executed zero HTTP requests",
        "public target support remains disabled",
        "fuzzing remains dry-run only",
        "exploit payloads remain prohibited",
        "login attempts remain prohibited",
        "broad crawling remains prohibited",
    ],
}

out.joinpath("dryrun-summary.json").write_text(
    json.dumps(summary, indent=2, sort_keys=True),
    encoding="utf-8",
)

md = [
    "# OpenMythos Active Dry-Run Evidence Report",
    "",
    f"- URL: `{url}`",
    f"- Mode: `{summary['mode']}`",
    f"- Passive report present: `{summary['passive_report_present']}`",
    "",
    "## Active Dry-Run",
    "",
    f"- OK: `{summary['active_dry_run']['ok']}`",
    f"- Blocked: `{summary['active_dry_run']['blocked']}`",
    f"- Executes requests: `{summary['active_dry_run']['executes_requests']}`",
    f"- Execution blocked: `{summary['active_dry_run']['execution_blocked']}`",
    f"- Planned request count: `{summary['active_dry_run']['planned_request_count']}`",
    f"- Reason: `{summary['active_dry_run']['reason']}`",
    "",
    "## Bounded Fuzzing Dry-Run",
    "",
    f"- OK: `{summary['fuzz_dry_run']['ok']}`",
    f"- Blocked: `{summary['fuzz_dry_run']['blocked']}`",
    f"- Executes requests: `{summary['fuzz_dry_run']['executes_requests']}`",
    f"- Execution blocked: `{summary['fuzz_dry_run']['execution_blocked']}`",
    f"- Planned case count: `{summary['fuzz_dry_run']['planned_case_count']}`",
    f"- Reason: `{summary['fuzz_dry_run']['reason']}`",
    "",
    "## Safety Assertions",
    "",
]

for item in summary["safety_assertions"]:
    md.append(f"- {item}")

md.extend([
    "",
    "## Evidence Files",
    "",
    "- `passive-audit.console.txt`",
    "- `latest_lab_report.md`",
    "- `latest_lab_report.json`",
    "- `active-dry-run.json`",
    "- `fuzz-dry-run.json`",
    "- `dryrun-summary.json`",
    "- `mcp_audit_tail.jsonl`",
    "- `git_state.txt`",
    "- `docker_state.txt`",
    "",
])

out.joinpath("dryrun-summary.md").write_text("\n".join(md), encoding="utf-8")

if active.get("executes_requests") is not False:
    raise SystemExit("[!] active dry-run must execute zero requests")

if fuzz.get("executes_requests") is not False:
    raise SystemExit("[!] fuzz dry-run must execute zero requests")

if fuzz.get("planned_case_count", 999999) > 10:
    raise SystemExit("[!] fuzz dry-run exceeded request cap")

print("[+] Wrote dry-run summary:", out / "dryrun-summary.md")
PY

echo "[+] Evidence report complete:"
echo "    $OUT/dryrun-summary.md"
