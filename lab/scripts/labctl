#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
COMPOSE_FILE="$ROOT/lab/docker/compose.localhost.yml"

compose() {
  if docker compose version >/dev/null 2>&1; then
    docker compose -f "$COMPOSE_FILE" "$@"
  elif command -v docker-compose >/dev/null 2>&1; then
    docker-compose -f "$COMPOSE_FILE" "$@"
  else
    echo "[!] Docker Compose is not installed."
    echo "    Try: sudo apt install -y docker-compose"
    exit 1
  fi
}

case "${1:-status}" in
  up)
    compose up -d
    compose ps
    ;;
  down)
    compose down
    ;;
  logs)
    compose logs --tail=120 -f
    ;;
  status)
    compose ps
    ;;
  url)
    echo "http://127.0.0.1:3000"
    ;;
  test)
    curl -I --max-time 5 http://127.0.0.1:3000 || true
    ;;
  *)
    echo "Usage: $0 {up|down|logs|status|url|test}"
    exit 1
    ;;
esac
